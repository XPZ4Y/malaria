---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="JWARA.AI Dashboard" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<div class="app">
			<header class="topbar">
				<div class="logo">JWARA.AI</div>
				<div class="header-actions">
					<button id="theme-toggle" class="theme-btn" aria-label="Toggle theme">
						<svg id="sun-icon" class="hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
						<svg id="moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
					</button>
					<div class="badge">DASHBOARD</div>
				</div>
			</header>
			<main class="content">
				<slot />
			</main>
		</div>

		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();
		
			if (theme === 'light') {
				document.documentElement.classList.remove('dark');
			} else {
				document.documentElement.classList.add('dark');
			}

			window.localStorage.setItem('theme', theme);

			const handleToggleClick = () => {
				const element = document.documentElement;
				element.classList.toggle("dark");
				
				const isDark = element.classList.contains("dark");
				localStorage.setItem("theme", isDark ? "dark" : "light");
				updateIcons();
			}

			const updateIcons = () => {
				const isDark = document.documentElement.classList.contains("dark");
				document.getElementById('sun-icon').classList.toggle('hidden', !isDark);
				document.getElementById('moon-icon').classList.toggle('hidden', isDark);
			}

			document.getElementById("theme-toggle").addEventListener("click", handleToggleClick);
			updateIcons();
		</script>
	</body>
</html>
<style is:global>
	:root {
		--primary: #8A0303;
		--light: #fff5f5;
		--border: rgba(138, 3, 3, 0.12);
		--bg-app: #fff;
		--bg-body: #f5f5f5;
		--bg-card: var(--light);
		--bg-table-head: #fafafa;
		--text: #8A0303;
		--text-muted: #666;
		--text-sub: #777;
	}

	:root.dark {
		--primary: #ff4d4d;
		--light: #2d0000;
		--border: rgba(255, 77, 77, 0.2);
		--bg-app: #1a1a1a;
		--bg-body: #121212;
		--bg-card: #251212;
		--bg-table-head: #222;
		--text: #ff9999;
		--text-muted: #ccc;
		--text-sub: #aaa;
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	body {
		font-family: 'DM Sans', sans-serif;
		background: var(--bg-body);
		color: var(--text);
		display: flex;
		justify-content: center;
		min-height: 100vh;
		transition: background 0.3s, color 0.3s;
	}

	.app {
		width: 100%;
		max-width: 1200px;
		background: var(--bg-app);
		position: relative;
		min-height: 100vh;
		box-shadow: 0 0 20px rgba(0, 0, 0, 0.2);
		transition: background 0.3s;
	}

	.topbar {
		padding: 20px 40px;
		display: flex;
		justify-content: space-between;
		align-items: center;
		border-bottom: 1px solid var(--border);
		position: sticky;
		top: 0;
		background: var(--bg-app);
		z-index: 10;
		transition: background 0.3s;
	}

	.header-actions {
		display: flex;
		align-items: center;
		gap: 16px;
	}

	.theme-btn {
		background: none;
		border: 1px solid var(--border);
		color: var(--text);
		padding: 8px;
		border-radius: 12px;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.2s;
	}

	.theme-btn:hover {
		background: var(--light);
	}

	.theme-btn svg {
		width: 20px;
		height: 20px;
	}

	.hidden {
		display: none;
	}

	.logo {
		font-size: 24px;
		font-weight: 700;
		letter-spacing: -1px;
		color: var(--primary);
	}

	.badge {
		background: var(--light);
		color: var(--primary);
		padding: 7px 12px;
		border-radius: 50px;
		font-size: 12px;
		font-weight: 600;
		border: 1px solid var(--border);
	}

	.content {
		padding: 40px;
	}

	h1 {
		font-size: 32px;
		line-height: 1.1;
		margin-bottom: 24px;
		letter-spacing: -1px;
		color: var(--text);
	}

	.stats {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 20px;
		margin-bottom: 40px;
	}

	.card {
		background: var(--bg-card);
		border-radius: 18px;
		padding: 24px;
		border: 1px solid var(--border);
		transition: background 0.3s;
	}

	.card small {
		color: var(--text-sub);
		font-size: 14px;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	.card h3 {
		margin-top: 12px;
		font-size: 36px;
		color: var(--primary);
	}

	.table-container {
		width: 100%;
		overflow-x: auto;
		background: var(--bg-app);
		border: 1px solid var(--border);
		border-radius: 18px;
		transition: background 0.3s;
	}

	table {
		width: 100%;
		border-collapse: collapse;
		text-align: left;
	}

	th {
		background: var(--bg-table-head);
		padding: 16px;
		font-size: 13px;
		font-weight: 700;
		color: var(--text-muted);
		text-transform: uppercase;
		letter-spacing: 1px;
		border-bottom: 1px solid var(--border);
		transition: background 0.3s;
	}

	td {
		padding: 16px;
		border-bottom: 1px solid var(--border);
		font-size: 14px;
		color: var(--text-muted);
	}

	tr:last-child td {
		border-bottom: none;
	}

	tr:hover {
		background: var(--bg-table-head);
	}

	.status-pill {
		font-size: 11px;
		padding: 6px 12px;
		border-radius: 30px;
		font-weight: 700;
		letter-spacing: 0.5px;
		display: inline-block;
	}

	.status-positive {
		background: #ffe5e5;
		color: #8A0303;
	}

	.status-negative {
		background: #e6fff5;
		color: #008f5a;
	}

	.dark .status-positive {
		background: #4d0000;
		color: #ff9999;
	}

	.dark .status-negative {
		background: #00331a;
		color: #99ffcc;
	}

	@media (max-width: 768px) {
		.content {
			padding: 20px;
		}
		
		.topbar {
			padding: 20px;
		}
	}
</style>
